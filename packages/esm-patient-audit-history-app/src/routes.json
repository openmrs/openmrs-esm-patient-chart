{
  "$schema": "https://json.openmrs.org/routes.schema.json",
  "backendDependencies": {
    "webservices.rest": ">=2.2.0"
  },
  "optionalBackendDependencies": {
    "auditlogweb": {
      "version": "^1.1.0-SNAPSHOT || >=2.0.0-0",
      "feature": {
        "flagName": "patient-audit-history",
        "label": "Patient Audit History",
        "description": "Enables the patient chart Audit History tab. Requires the backend auditlogweb module with the patient audit endpoint (/auditlogs/patients)."
      }
    }
  },
  "extensions": [
    {
      "name": "patient-audit-history-dashboard-link",
      "component": "auditHistoryDashboardLink",
      "slot": "patient-chart-dashboard-slot",
      "order": 18,
      "featureFlag": "patient-audit-history",
      "privileges": "View Audit Logs",
      "meta": {
        "slot": "patient-chart-audit-history-dashboard-slot",
        "path": "audit-history"
      }
    },
    {
      "name": "patient-audit-history-details-widget",
      "component": "auditHistoryDashboard",
      "slot": "patient-chart-audit-history-dashboard-slot",
      "featureFlag": "patient-audit-history",
      "privileges": "View Audit Logs",
      "meta": {
        "fullWidth": true
      }
    }
  ]
}
