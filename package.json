{
  "name": "@openmrs/esm-patient-chart",
  "private": true,
  "version": "12.3.4",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "openmrs develop --sources packages/esm-patient-chart-app/",
    "ci:publish": "yarn workspaces foreach --all --topological --exclude @openmrs/esm-patient-chart npm publish --access public --tag latest",
    "ci:prepublish": "yarn workspaces foreach --all --topological --exclude @openmrs/esm-patient-chart npm publish --access public --tag next",
    "ci:prepublish-patch": "yarn workspaces foreach --all --topological --exclude @openmrs/esm-patient-chart npm publish --access public --tag patch",
    "ci:bump-form-engine-lib": "yarn up @openmrs/esm-form-engine-lib@latest",
    "release": "yarn workspaces foreach --all --topological version",
    "verify": "turbo run lint typescript test --color --concurrency=5",
    "test": "turbo run test --color",
    "coverage": "turbo run coverage --color",
    "postinstall": "husky install",
    "test-e2e": "playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.1",
    "classnames": "^2.3.2",
    "react-barcode": "^1.5.3",
    "react-hook-form": "^7.46.2",
    "react-to-print": "^2.14.13",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@playwright/test": "^1.51.1",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.89",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/fhir": "^0.0.31",
    "@types/lodash-es": "^4.17.9",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-preset-minify": "^0.5.2",
    "concurrently": "^8.2.1",
    "cross-env": "^10.1.0",
    "d3-selection": "^3.0.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest-dom": "^5.4.0",
    "eslint-plugin-playwright": "^0.16.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.2",
    "happy-dom": "^20.0.0",
    "husky": "^8.0.3",
    "i18next": "^25.0.0",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^28.0.0",
    "lint-staged": "^14.0.1",
    "lodash": "^4.18.1",
    "openmrs": "next",
    "prettier": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.30.4",
    "rxjs": "^6.6.7",
    "sass": "^1.54.3",
    "swr": "2.2.5",
    "turbo": "^2.9.14",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2",
    "webpack-dev-server": "^5.2.4"
  },
  "lint-staged": {
    "packages/**/src/**/*.{ts,tsx}": "eslint --cache --fix --max-warnings 0",
    "*.{css,scss,ts,tsx}": "prettier --write --list-different"
  },
  "resolutions": {
    "sass": "^1.54.3",
    "shell-quote": ">=1.8.4",
    "@remix-run/router": "^1.23.3",
    "react-router-dom": "^6.30.4",
    "cross-spawn": "^7.0.6",
    "jpeg-js": "^0.4.4",
    "immutable": "^5.1.3",
    "serialize-javascript": "^7.0.0",
    "@sigstore/core": "^3.2.1",
    "@tootallnate/once": "^2.0.1",
    "brace-expansion@npm:^1.0.0": "^1.1.15",
    "brace-expansion@npm:^2.0.0": "^2.1.1",
    "brace-expansion@npm:^5.0.0": "^5.0.7",
    "cookie@npm:^0.4.0": "^0.7.2",
    "dompurify": "3.4.1",
    "fast-uri": "^3.1.3",
    "hono": "^4.12.27",
    "http-proxy-middleware@npm:^2.0.0": "^2.0.10",
    "lodash": "^4.18.1",
    "micromatch": "^4.0.8",
    "picomatch@npm:^2.0.0": "^2.3.2",
    "qs": "^6.15.3",
    "tar@npm:^7.0.0": "^7.5.19",
    "tmp": "^0.2.7",
    "undici": "^7.28.0",
    "ws@npm:^8.0.0": "^8.21.0",
    "xml2js": "^0.6.2"
  },
  "packageManager": "yarn@4.10.3"
}
